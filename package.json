{
  "name": "randomness",
  "version": "1.0.18",
  "description": "IPP3-compatible random generator engine for Obsidian",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:engine": "jest __tests__/engine",
    "test:integration": "jest __tests__/integration",
    "embed-reference": "node scripts/embed-reference.mjs"
  },
  "keywords": [
    "obsidian",
    "ttrpg",
    "generator",
    "ipp3"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "obsidian": "^1.4.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  }
}